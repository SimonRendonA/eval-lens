# EvalLens environment template
# Copy this file to .env.local (or .env) and fill values as needed.

# App mode:
# - hosted: evaluate uploaded expected/actual files only
# - self-hosted: enables provider-based output generation and failure analysis
EVALLENS_MODE=hosted

# Public base URL used by Next metadata (Open Graph/Twitter image resolution).
# Examples:
# - https://rendonarango.com
# - https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Provider API keys (used only in self-hosted mode).
# Set at least one key when EVALLENS_MODE=self-hosted.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: force mock generation in /api/generate for local testing.
# true  => uses mock outputs, no provider API calls
# false => uses real provider SDKs and keys above
USE_MOCK_GENERATION=false
